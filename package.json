{
  "name": "retirement-lead-qualification-bot",
  "version": "1.0.0",
  "description": "AI-powered retirement lead qualification assistant",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec node --loader ts-node/esm src/server.ts",
    "client:dev": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "vite build",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": ["retirement", "qualification", "chatbot", "openai"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "openai": "^4.24.0",
    "elevenlabs": "^0.2.26",
    "axios": "^1.6.0",
    "mongoose": "^8.0.0",
    "node-cron": "^3.0.2",
    "jsonwebtoken": "^9.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "concurrently": "^8.2.2"
  }
}
